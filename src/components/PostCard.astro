---
interface Props {
  title: string;
  date: Date;
  description?: string;
  slug: string;
  tags?: string[];
  style?: string;
}

const { title, date, description, slug, tags, style } = Astro.props;
const formattedDate = date.toLocaleDateString("en-US", {
  year: "numeric",
  month: "short",
  day: "numeric",
});
---

<a href={`/blog/${slug}`} class="block group" style={style}>
  <article class="relative p-4 rounded-lg border border-[var(--color-border)] bg-[var(--color-surface)] glow-hover overflow-hidden transition-all duration-300 hover:border-[var(--color-border-active)]">
    <div class="absolute left-0 top-0 bottom-0 w-[3px] bg-gradient-to-b from-[#06b6d4] to-[#10b981] opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
    <div class="flex items-baseline justify-between gap-4">
      <h3 class="font-medium text-[var(--color-text)] group-hover:text-[var(--color-accent)] transition-colors">
        {title}
      </h3>
      <time
        datetime={date.toISOString()}
        class="text-sm font-mono text-[var(--color-text-muted)] shrink-0"
      >
        {formattedDate}
      </time>
    </div>
    {description && (
      <p class="mt-2 text-sm text-[var(--color-text-secondary)]">{description}</p>
    )}
    {tags && tags.length > 0 && (
      <div class="mt-3 flex gap-2">
        {tags.map((tag) => (
          <span class="tag-badge">
            {tag}
          </span>
        ))}
      </div>
    )}
  </article>
</a>

<style>
  .tag-badge {
    padding: 0.125rem 0.5rem;
    border-radius: 9999px;
    font-size: 0.75rem;
    font-family: "JetBrains Mono", ui-monospace, monospace;
    white-space: nowrap;
    flex-shrink: 0;
    color: var(--color-accent);
    background-color: color-mix(in srgb, var(--color-accent) 10%, transparent);
    border: 1px solid color-mix(in srgb, var(--color-accent) 20%, transparent);
  }
</style>
