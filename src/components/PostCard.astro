---
interface Props {
  title: string;
  date: Date;
  description?: string;
  slug: string;
}

const { title, date, description, slug } = Astro.props;
const formattedDate = date.toLocaleDateString("en-US", {
  year: "numeric",
  month: "short",
  day: "numeric",
});
---

<a href={`/blog/${slug}`} class="block group">
  <article class="py-4">
    <div class="flex items-baseline justify-between gap-4">
      <h3 class="font-medium group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors">
        {title}
      </h3>
      <time
        datetime={date.toISOString()}
        class="text-sm text-slate-500 dark:text-slate-400 shrink-0"
      >
        {formattedDate}
      </time>
    </div>
    {description && (
      <p class="mt-1 text-sm text-slate-600 dark:text-slate-400">{description}</p>
    )}
  </article>
</a>
