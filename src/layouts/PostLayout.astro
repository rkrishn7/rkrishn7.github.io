---
import BaseLayout from "./BaseLayout.astro";

interface Props {
  title: string;
  description?: string;
  date: Date;
  tags?: string[];
}

const { title, description, date, tags } = Astro.props;
const formattedDate = date.toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
---

<BaseLayout title={`${title} | @rkrishn7`} description={description}>
  <article>
    <div class="mb-6">
      <a
        href="/blog"
        class="text-sm font-mono text-[var(--color-text-muted)] hover:text-[var(--color-accent)] transition-colors"
      >
        &larr; back to blog
      </a>
    </div>
    <header class="mb-8">
      <h1 class="text-3xl font-bold font-mono mb-3">{title}</h1>
      <div class="flex items-center gap-3 text-sm text-[var(--color-text-muted)]">
        <time datetime={date.toISOString()} class="font-mono">{formattedDate}</time>
        {
          tags && tags.length > 0 && (
            <div class="flex gap-2">
              {tags.map((tag) => (
                <span class="px-2 py-0.5 rounded-full text-xs font-mono bg-[var(--color-accent)]/10 text-[var(--color-accent)]">
                  {tag}
                </span>
              ))}
            </div>
          )
        }
      </div>
      <div class="mt-4 h-[2px] bg-gradient-to-r from-[#06b6d4] to-[#10b981] rounded-full"></div>
    </header>
    <div class="prose max-w-none">
      <slot />
    </div>
  </article>
</BaseLayout>
