---
import BaseLayout from "./BaseLayout.astro";

interface Props {
  title: string;
  description?: string;
  date: Date;
  tags?: string[];
  minutesRead?: string;
}

const { title, description, date, tags, minutesRead } = Astro.props;
const formattedDate = date.toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
---

<BaseLayout title={`${title} | @rkrishn7`} description={description}>
  <article>
    <div class="mb-6">
      <a
        href="/blog"
        class="text-sm font-mono text-[var(--color-text-muted)] hover:text-[var(--color-accent)] transition-colors"
      >
        &larr; back to blog
      </a>
    </div>
    <header class="mb-8">
      <h1 class="text-3xl font-bold font-mono mb-3">{title}</h1>
      <div class="text-sm text-[var(--color-text-muted)]">
        <time datetime={date.toISOString()} class="font-mono">{formattedDate}</time>
        {minutesRead && <span class="font-mono"> · {minutesRead}</span>}
        {
          tags && tags.length > 0 && (
            <div style="display: flex; flex-wrap: wrap; gap: 0.5rem; margin-top: 0.5rem;">
              {tags.map((tag) => (
                <span style="white-space: nowrap; padding: 0.125rem 0.5rem; border-radius: 9999px; font-size: 0.75rem; font-family: 'JetBrains Mono', ui-monospace, monospace; color: var(--color-accent); background-color: color-mix(in srgb, var(--color-accent) 10%, transparent); border: 1px solid color-mix(in srgb, var(--color-accent) 20%, transparent);">
                  {tag}
                </span>
              ))}
            </div>
          )
        }
      </div>
      <div class="mt-4 h-[2px] bg-gradient-to-r from-[#06b6d4] to-[#10b981] rounded-full"></div>
    </header>
    <div class="prose max-w-none">
      <slot />
    </div>
  </article>
</BaseLayout>
