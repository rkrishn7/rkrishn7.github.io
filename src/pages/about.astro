---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="About | rohank">
  <h1 class="text-3xl font-bold mb-8">About</h1>
  <div class="prose dark:prose-invert max-w-none">
    <p>
      Hi, I'm Rohan Krishnaswamy — a software engineer based in Toronto.
    </p>
    <p>
      I'm interested in systems programming, distributed systems, and the tools
      we use to build software. This site is where I write about things I've
      learned and problems I've found interesting.
    </p>
    <p>
      You can find me on <a href="https://github.com/rkrishn7">GitHub</a> or
      reach me via <a href="mailto:rohan@fastmail.us">email</a>.
    </p>
  </div>
</BaseLayout>
