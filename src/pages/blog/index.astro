---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PostCard from "../../components/PostCard.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog", ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout title="Blog | @rkrishn7">
  <h1 class="font-mono text-3xl font-bold mb-8">
    <span class="text-[var(--color-text-muted)]">//</span> blog
  </h1>
  {posts.length > 0 ? (
    <div class="flex flex-col gap-3">
      {posts.map((post, i) => (
        <div class="fade-up" style={`transition-delay: ${i * 100}ms`}>
          <PostCard
            title={post.data.title}
            date={post.data.date}
            description={post.data.description}
            slug={post.slug}
            tags={post.data.tags}
          />
        </div>
      ))}
    </div>
  ) : (
    <p class="text-[var(--color-text-muted)]">No posts yet.</p>
  )}
</BaseLayout>
