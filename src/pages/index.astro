---
import BaseLayout from "../layouts/BaseLayout.astro";
import PostCard from "../components/PostCard.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog", ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 5);
---

<BaseLayout title="rohank">
  <section class="mb-12">
    <h1 class="text-3xl font-bold mb-4">Hey, I'm Rohan</h1>
    <p class="text-slate-600 dark:text-slate-400 leading-relaxed">
      Software engineer. I write about systems, programming, and whatever else I find interesting.
    </p>
  </section>

  <section>
    <h2 class="text-xl font-semibold mb-4">Recent Posts</h2>
    {posts.length > 0 ? (
      <div class="divide-y divide-slate-200 dark:divide-slate-700">
        {posts.map((post) => (
          <PostCard
            title={post.data.title}
            date={post.data.date}
            description={post.data.description}
            slug={post.slug}
          />
        ))}
      </div>
    ) : (
      <p class="text-slate-500 dark:text-slate-400">No posts yet.</p>
    )}
  </section>
</BaseLayout>
