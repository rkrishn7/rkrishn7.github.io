---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

export async function getStaticPaths() {
  const talks = await getCollection("talks");
  return talks.map((talk) => ({
    params: { slug: talk.slug },
    props: talk,
  }));
}

const talk = Astro.props;
const { Content } = await talk.render();
const { title, event, date, videoUrl, startAt, tags, description } = talk.data;
const plainTitle = title.replace(/<[^>]*>/g, "");

const formattedDate = date.toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});

let embedUrl = videoUrl;
if (startAt) {
  if (videoUrl.includes("player.vimeo.com")) {
    embedUrl = `${videoUrl}#t=${startAt}s`;
  } else {
    const sep = videoUrl.includes("?") ? "&" : "?";
    embedUrl = `${videoUrl}${sep}start=${startAt}`;
  }
}
---

<BaseLayout title={`${plainTitle} | @rkrishn7`} description={description}>
  <article>
    <div class="mb-6">
      <a
        href="/talks"
        class="text-sm font-mono text-[var(--color-text-muted)] hover:text-[var(--color-accent)] transition-colors"
      >
        &larr; back to talks
      </a>
    </div>
    <header class="mb-8">
      <h1 class="text-3xl font-bold font-mono mb-3" set:html={title} />
      <div class="flex items-center gap-3 text-sm text-[var(--color-text-muted)]">
        <span class="font-mono text-[var(--color-accent)]">{event}</span>
        <span>&middot;</span>
        <time datetime={date.toISOString()} class="font-mono">{formattedDate}</time>
      </div>
      {tags && tags.length > 0 && (
        <div class="mt-3 flex gap-2">
          {tags.map((tag) => (
            <span class="px-2 py-0.5 rounded-full text-xs font-mono bg-[var(--color-accent)]/10 text-[var(--color-accent)] border border-[var(--color-accent)]/20">
              {tag}
            </span>
          ))}
        </div>
      )}
      <div class="mt-4 h-[2px] bg-gradient-to-r from-[#06b6d4] to-[#10b981] rounded-full"></div>
    </header>
    <div class="mb-8 aspect-video rounded-lg overflow-hidden border border-[var(--color-border)]">
      <iframe
        src={embedUrl}
        title={plainTitle}
        class="w-full h-full"
        frameborder="0"
        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
        allowfullscreen
      ></iframe>
    </div>
    <div class="prose max-w-none">
      <Content />
    </div>
  </article>
</BaseLayout>
